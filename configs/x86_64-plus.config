CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_ROOTFS_PARTSIZE=1024

# ------------------------------------------------------------
# LuCI (Plus UI)
# ------------------------------------------------------------
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-theme-argon=y

# LuCI apps (essential)
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-app-ttyd=y

# ------------------------------------------------------------
# Tools & Libraries
# ------------------------------------------------------------
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_libstdcpp=y

# ------------------------------------------------------------
# Base security
# ------------------------------------------------------------
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_openssl-util=y

# ------------------------------------------------------------
# Network utilities
# ------------------------------------------------------------
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_ethtool=y
CONFIG_PACKAGE_resolveip=y
CONFIG_PACKAGE_mtr-json=y

# ------------------------------------------------------------
# Firewall / nftables stack (fw4) — primary
# ------------------------------------------------------------
CONFIG_PACKAGE_iptables-nft=y

# ------------------------------------------------------------
# DNS Services (Prefer dnsmasq-full)
# AdGuard Home takes port 53; dnsmasq is moved to 5353
# by uci-defaults/60-adguardhome-dns at first boot.
# ------------------------------------------------------------
CONFIG_PACKAGE_dnsmasq-full=y
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_adguardhome=y

# ------------------------------------------------------------
# Kernel: nftables & TProxy (for passwall2 nftables mode)
# ------------------------------------------------------------
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-br-netfilter=y
CONFIG_PACKAGE_kmod-nft-socket=y
CONFIG_PACKAGE_kmod-nft-compat=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nft-nat=y

# ------------------------------------------------------------
# Kernel: iptables compat (passwall2 iptables fallback mode)
# ------------------------------------------------------------
CONFIG_PACKAGE_kmod-ipt-core=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-ipt-tproxy=y

# ------------------------------------------------------------
# IPv6 support
# ------------------------------------------------------------
CONFIG_PACKAGE_kmod-ip6tables=y
CONFIG_PACKAGE_ip6tables=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y

# ------------------------------------------------------------
# WireGuard VPN
# ------------------------------------------------------------
CONFIG_PACKAGE_wireguard-tools=y
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_luci-app-wireguard=y
CONFIG_PACKAGE_luci-proto-wireguard=y
CONFIG_PACKAGE_qrencode=y

# ------------------------------------------------------------
# DDNS
# ------------------------------------------------------------
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_ddns-scripts-cloudflare=y
CONFIG_PACKAGE_ddns-scripts-noip=y

# ------------------------------------------------------------
# UPnP / NAT-PMP
# Disabled by default at runtime; enable via LuCI if needed.
# ------------------------------------------------------------
CONFIG_PACKAGE_miniupnpd-nftables=y
CONFIG_PACKAGE_luci-app-upnp=y

# ------------------------------------------------------------
# Threat blocking (banip)
# ------------------------------------------------------------
CONFIG_PACKAGE_banip=y
CONFIG_PACKAGE_luci-app-banip=y

# ------------------------------------------------------------
# Traffic monitoring
# ------------------------------------------------------------
CONFIG_PACKAGE_nlbwmon=y
CONFIG_PACKAGE_luci-app-nlbwmon=y

# ------------------------------------------------------------
# System statistics
# ------------------------------------------------------------
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_collectd=y
CONFIG_PACKAGE_collectd-mod-cpu=y
CONFIG_PACKAGE_collectd-mod-interface=y
CONFIG_PACKAGE_collectd-mod-load=y
CONFIG_PACKAGE_collectd-mod-memory=y
CONFIG_PACKAGE_collectd-mod-network=y

# ------------------------------------------------------------
# Multi-WAN load balancing
# ------------------------------------------------------------
CONFIG_PACKAGE_mwan3=y
CONFIG_PACKAGE_luci-app-mwan3=y

# ------------------------------------------------------------
# Wake-on-LAN
# ------------------------------------------------------------
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_etherwake=y

# ------------------------------------------------------------
# Password utilities (htpasswd for AdGuard Home credential management)
# ------------------------------------------------------------

# ------------------------------------------------------------
# Passwall2 core dependencies (offline-ready)
# These match LUCI_DEPENDS in passwall2 Makefile v26.3.5
# ------------------------------------------------------------
CONFIG_PACKAGE_tcping=y
CONFIG_PACKAGE_geoview=y
CONFIG_PACKAGE_v2ray-geoip=y
CONFIG_PACKAGE_v2ray-geosite=y

# Runtime deps
CONFIG_PACKAGE_libev=y
CONFIG_PACKAGE_libsodium=y
CONFIG_PACKAGE_libudns=y

CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-netlink-diag=y

CONFIG_PACKAGE_coreutils=y
CONFIG_PACKAGE_coreutils-base64=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_libuci-lua=y

# Proxy engines
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_sing-box=y

# Additional passwall2 runtime deps (explicit)
CONFIG_PACKAGE_lua=y
CONFIG_PACKAGE_luci-lib-jsonc=y
